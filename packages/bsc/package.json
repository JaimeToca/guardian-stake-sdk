{
  "name": "@guardian/bsc",
  "version": "0.1.0",
  "description": "Guardian SDK for BNB Smart Chain",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cjs/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.esm.json",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "viem": "^2.47.5"
  },
  "dependencies": {
    "@guardian/sdk": "*"
  },
  "devDependencies": {
    "viem": "^2.47.6",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "bnb",
    "bsc",
    "binance",
    "staking",
    "web3",
    "blockchain",
    "sdk",
    "guardian",
    "native-staking",
    "bnb-smart-chain"
  ],
  "author": "JaimeToca",
  "repository": {
    "type": "git",
    "url": "https://github.com/JaimeToca/bnb-native-staking.git"
  },
  "license": "MIT"
}
