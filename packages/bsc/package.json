{
  "name": "@guardian/bsc",
  "version": "0.1.0",
  "description": "Guardian SDK for BNB Smart Chain",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "viem": "^2.47.5"
  },
"devDependencies": {
    "tsup": "^8.5.1",
    "viem": "^2.47.6",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "bnb",
    "bsc",
    "binance",
    "staking",
    "native-staking",
    "bnb-smart-chain",
    "web3",
    "blockchain",
    "sdk",
    "guardian",
    "guardian-sdk",
    "guardian-stake-sdk"
  ],
  "author": "JaimeToca",
  "repository": {
    "type": "git",
    "url": "https://github.com/JaimeToca/guardian-stake-sdk.git"
  },
  "license": "MIT"
}
