{
  "name": "@guardian/sdk",
  "version": "1.0.0",
  "description": "Chain-agnostic core for the Guardian SDK",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cjs/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./testing": {
      "types": "./dist/cjs/testing/index.d.ts",
      "import": "./dist/esm/testing/index.js",
      "require": "./dist/cjs/testing/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.esm.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "axios": "^1.13.6"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "guardian",
    "sdk",
    "staking",
    "blockchain",
    "web3"
  ],
  "author": "JaimeToca",
  "repository": {
    "type": "git",
    "url": "https://github.com/JaimeToca/bnb-native-staking.git"
  },
  "license": "MIT"
}
