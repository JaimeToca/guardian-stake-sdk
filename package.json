{
  "name": "guardian-sdk",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w packages/sdk && npm run build -w packages/bsc",
    "typecheck": "npm run build -w packages/sdk && npm run typecheck --workspaces --if-present",
    "test": "npm test -w packages/bsc",
    "docs": "typedoc",
    "lint": "eslint packages/*/src packages/*/tests",
    "lint:fix": "eslint packages/*/src packages/*/tests --fix",
    "format": "prettier --write packages/*/src packages/*/tests",
    "format:check": "prettier --check packages/*/src packages/*/tests",
    "release": "semantic-release"
  },
  "engines": {
    "node": ">=18"
  },
  "author": "JaimeToca",
  "license": "MIT",
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@typescript-eslint/eslint-plugin": "8.57.2",
    "@typescript-eslint/parser": "8.57.2",
    "eslint": "10.1.0",
    "eslint-config-prettier": "10.1.8",
    "prettier": "3.8.1",
    "semantic-release": "^25.0.3",
    "typedoc": "^0.28.18",
    "typedoc-plugin-merge-modules": "^7.0.0"
  }
}
