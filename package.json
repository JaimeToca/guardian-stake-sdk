{
  "name": "guardian-sdk",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "build": "pnpm --filter @guardian-sdk/sdk run build && pnpm --filter @guardian-sdk/bsc run build && pnpm --filter @guardian-sdk/cardano run build",
    "typecheck": "pnpm -r run typecheck && tsc --noEmit -p examples/tsconfig.json",
    "test": "pnpm --filter @guardian-sdk/bsc run test && pnpm --filter @guardian-sdk/cardano run test",
    "docs": "typedoc",
    "lint": "eslint packages/*/src packages/*/tests",
    "lint:fix": "eslint packages/*/src packages/*/tests --fix",
    "format": "prettier --write packages/*/src packages/*/tests",
    "format:check": "prettier --check packages/*/src packages/*/tests",
    "changeset": "changeset",
    "version": "changeset version",
    "publish": "pnpm build && changeset publish",
    "prepare": "sh scripts/install-hooks.sh"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "publicHoistPattern": [
      "@guardian-sdk/sdk"
    ],
    "confirmModulesPurge": false
  },
  "author": "JaimeToca",
  "license": "MIT",
  "devDependencies": {
    "@cardano-sdk/crypto": "^0.4.5",
    "@changesets/cli": "^2.30.0",
    "@guardian-sdk/sdk": "workspace:*",
    "@scure/bip32": "^2.0.1",
    "@scure/bip39": "^2.0.1",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typedoc": "^0.28.18",
    "typedoc-plugin-merge-modules": "^7.0.0",
    "typescript": "^6.0.2",
    "viem": "^2.47.10"
  }
}
